{
  "name": "launchkit",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Go-To-Market Teammate — paste a GitHub repo, get a full launch kit",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:apps",
    "build:shared": "npm run build -w packages/shared && npm run build -w packages/video",
    "build:apps": "npm run build -w apps/web && npm run build -w apps/worker && npm run build -w apps/cron && npm run build -w apps/dashboard",
    "video:studio": "npm run studio -w packages/video",
    "dev": "concurrently -n web,worker,cron,dash -c blue,green,yellow,magenta \"npm run dev -w apps/web\" \"npm run dev -w apps/worker\" \"npm run dev -w apps/cron\" \"npm run dev -w apps/dashboard\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:cron": "npm run dev -w apps/cron",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "start:web": "node apps/web/dist/index.js",
    "start:worker": "node apps/worker/dist/index.js",
    "start:cron": "node apps/cron/dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx seed.ts",
    "test:narration": "npm run build && node --test tests/narration.test.mjs",
    "test:agent": "npm run build && node --test --test-force-exit tests/agent-sdk-runner.test.mjs",
    "test": "npm run build && node --test --test-force-exit tests/*.test.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b && tsc --noEmit -p apps/dashboard/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0",
    "@types/pg": "^8.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
