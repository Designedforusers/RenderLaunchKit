FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .
RUN pip3 install --break-system-packages -r vendor/pikastream-video-meeting/requirements.txt && \
    npm ci --include=dev && \
    npm run build

CMD ["npm", "run", "start:pika-worker"]
