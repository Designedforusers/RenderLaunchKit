# Local editor / agent tooling — not tracked across the team.
# Exception: .claude/rules/ contains path-conditional project rules
# that Claude Code loads on demand (checked in so all contributors
# get them).
.claude/*
!.claude/rules/

# `npx skills add` (agentskills.io) install artifacts.
#
# The installer drops a per-agent shadow directory for every supported
# coding agent (.codebuddy, .commandcode, .crush, …) — each one a thin
# symlink redirect to the canonical universal location at
# `.agents/skills/`. We track ONLY the canonical location plus the
# `skills-lock.json` manifest so PR reviewers can see exactly which
# skills are active without cloning the symlink farm. Everything else
# (the per-agent shadow dirs, the top-level `skills/` symlink) is
# ignored noise — a `git status` after `npx skills add -y` is clean.
#
# To add a new skill: `npx skills add <source> -y`, then `git add`
# anything that lands under `.agents/skills/` and the updated
# `skills-lock.json`. Anything outside that allowlist stays ignored.
.agents/*
!.agents/skills/
.augment/
.bob/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/
.zencoder/
# Top-level `skills/` symlink the installer drops (redirects to
# `.agents/skills/`). Anchored to the repo root with a leading slash
# so it does NOT match `.agents/skills/`, which we explicitly track.
/skills/
docker-compose.override.yml
migrations/meta/
test-results/
