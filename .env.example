# Required API keys
ANTHROPIC_API_KEY=sk-ant-...
# Override the Claude model used by single-shot agents (writer,
# strategist, etc.). The research agent always runs through the Claude
# Agent SDK with Opus 4.6. Defaults to claude-opus-4-6.
ANTHROPIC_MODEL=claude-opus-4-6

# Voyage AI — embeddings provider. The canonical pairing for
# Anthropic-stack projects (Anthropic explicitly recommended Voyage
# before MongoDB acquired them; the recommendation still stands).
# `voyage-3-large` at 1024 dim is current SOTA for retrieval. Sign up
# at https://www.voyageai.com — 200M tokens free, then $0.18/M tokens.
# Required for any pgvector similarity search to produce meaningful
# results; without it, the embedding helper throws a structured error
# at call time and the worker still boots.
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

FAL_API_KEY=...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_TOKEN=ghp_...

# Private-repo support. Base64-encoded 32-byte secret used by the web
# service to encrypt user-supplied GitHub personal access tokens
# (AES-256-GCM) before persisting them on the `projects` row, and by
# the worker to decrypt at the start of an analyze job. Generate with:
#   node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# Optional — when unset, project creation rejects any request that
# includes a `githubToken` field with a 503 and the public-repo path
# keeps working unchanged.
GITHUB_TOKEN_SECRET=

# Trending signals (Phase 3) — the trending-signals agent fans out
# across Grok (live X search), Exa (semantic web search), and five
# free APIs (HN Algolia, dev.to, Reddit, Product Hunt, GitHub search).
# Both paid keys are optional: the agent skips sources whose key is
# absent rather than failing the whole ingest. Without Grok the live
# X signal is unavailable; without Exa the semantic web search falls
# back to the built-in Anthropic WebSearch.
GROK_API_KEY=xai-...
GROK_MODEL=grok-4-latest
EXA_API_KEY=...
# Product Hunt v2 GraphQL developer token. Free to obtain at
# https://api.producthunt.com/v2/oauth/applications. Optional — the
# tool returns an empty array when absent and the rest of the fan-out
# still runs.
PRODUCT_HUNT_TOKEN=
TRENDING_SIGNAL_CACHE_TTL_SECONDS=600
TRENDING_SIGNAL_TTL_HOURS=168

# ── ElevenLabs (worker audio synthesis: voice commercial + podcast) ──
# Drives the eager Phase 4 audio assets the worker writes into
# `.cache/elevenlabs-rendered/` for the dashboard streaming route to
# read back. `ELEVENLABS_VOICE_ID_ALT` is the second speaker (`sam`)
# in the multi-voice podcast; without it, the dialogue still renders
# but both speakers share the primary voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_ALT=
ELEVENLABS_MODEL_ID=
API_KEY=

# Database (Render provides this automatically)
DATABASE_URL=postgresql://user:pass@localhost:5432/launchkit

# Redis (Render provides this automatically)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
PORT=3000

# ── Render Workflows (asset generation runtime) ──────────────────
# The worker's strategize handler, the creative-review re-queue, the
# commit-marketing refresh, and the user-facing Regenerate route all
# trigger a `generateAllAssetsForProject` task on the workflows
# service via the helper at `apps/worker/src/lib/trigger-workflow-generation.ts`
# (and its mirror at `apps/web/src/lib/trigger-workflow-generation.ts`).
# Both vars are `.optional()` in the typed env schemas so the worker
# and web boot fine without them — the trigger helper throws a
# structured error at call time if either is missing rather than
# failing every service boot when the workflow service has not yet
# been provisioned.
#
# Production setup: create the workflow service via the Render
# dashboard (one-time, manual — Render Workflows is in public beta
# and `render.yaml` Blueprint syntax does not yet support workflow
# services), then copy the workflow slug from the Tasks page and a
# personal Render API key from Account Settings → API Keys, and
# paste them onto BOTH the worker AND web services. See `README.md`
# § "Deploy your own on Render in 4 steps" for the runbook.
RENDER_API_KEY=rnd_...
RENDER_WORKFLOW_SLUG=launchkit-workflows-...

# Local-development-only flag. Set to `true` and run
# `render workflows dev -- npm run dev -w apps/workflows` (or just
# `npm run dev` from the repo root, which includes the workflows
# service in the concurrently stack) so the Render SDK auto-routes
# every `client.workflows.startTask(...)` call to the local task
# server on `http://localhost:8120` instead of the Render control
# plane. Identical code path between local and prod — same task
# functions, same compute boundary, same retry logic, just running
# on your laptop. Do NOT set this on a deployed service.
RENDER_USE_LOCAL_DEV=true
